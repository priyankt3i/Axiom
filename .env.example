# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: HTTP port for the Express/Vite server.
PORT="3000"

# SESSION_SECRET: Required in production. Used to sign HTTP-only session cookies.
SESSION_SECRET="replace-with-a-long-random-secret"

# INTEGRATION_ENCRYPTION_KEY: Required in production. Used for encrypted provider credential storage.
INTEGRATION_ENCRYPTION_KEY="replace-with-a-long-random-secret-for-integrations"

# ENABLE_DEV_LOGIN: Set to true to allow local admin login outside development.
# In production, DEV_LOGIN_TOKEN is required and must be supplied as X-Dev-Login-Token.
ENABLE_DEV_LOGIN="false"
DEV_LOGIN_TOKEN=""

# ENABLE_LEGACY_DISPATCH: Set to true only if production must expose the legacy simulation endpoint.
# The primary UI uses /api/jobs; /api/dispatch is retained for local/demo compatibility.
ENABLE_LEGACY_DISPATCH="false"

# ENABLE_LOCAL_WORKFLOW_RUNNER: Set to true only for controlled production demos/staging runs.
# When false in production, /api/jobs rejects work instead of running the offline/local simulation path.
ENABLE_LOCAL_WORKFLOW_RUNNER="false"

# ENABLE_LOCAL_REVIEW_ACTIONS: Set to true only for controlled production demos/staging runs.
# When false in production, approve/rollback reject instead of recording simulated Git/Hermes actions.
ENABLE_LOCAL_REVIEW_ACTIONS="false"

# ENABLE_GITHUB_APP_REVIEW_ACTIONS: Set to true when GitHub App PR metadata is persisted on jobs
# and approve actions should merge through the GitHub App adapter.
ENABLE_GITHUB_APP_REVIEW_ACTIONS="false"

# ENABLE_GITHUB_APP_ROLLBACK_ACTIONS: Set to true when rollback should delete GitHub feature
# branches through the GitHub App adapter and evict Hermes memory through the webhook below.
ENABLE_GITHUB_APP_ROLLBACK_ACTIONS="false"
HERMES_MEMORY_EVICTION_WEBHOOK_URL=""
HERMES_MEMORY_EVICTION_WEBHOOK_TOKEN=""
HERMES_MEMORY_EVICTION_WEBHOOK_TIMEOUT_MS="5000"

# INVITE_TOKEN_TTL_HOURS: Lifetime for one-time signed invitation links.
INVITE_TOKEN_TTL_HOURS="168"
# Optional invite email delivery webhook. When unset, invite links are generated for manual copy.
INVITE_EMAIL_WEBHOOK_URL=""
INVITE_EMAIL_WEBHOOK_TOKEN=""
INVITE_EMAIL_WEBHOOK_TIMEOUT_MS="5000"

# GitHub OAuth sign-in. Callback URL must be APP_URL + /api/auth/github/callback.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_OAUTH_SCOPES="read:user user:email repo"
# Optional override for GitHub API base URL. Leave unset for github.com.
GITHUB_API_BASE_URL="https://api.github.com"
# Optional comma-separated domains that may self-provision through GitHub OAuth in production.
# Existing invited/active users can still sign in without this.
GITHUB_ALLOWED_EMAIL_DOMAINS=""
# Optional comma-separated GitHub organizations that may self-provision through GitHub OAuth in production.
# When set, the server requests `read:org` during OAuth authorization.
GITHUB_ALLOWED_ORGS=""
# Optional comma-separated org/team-slug entries that may self-provision through GitHub OAuth in production.
# When set, the server requests `read:org` during OAuth authorization.
GITHUB_ALLOWED_TEAMS=""

# Optional production storage adapter. When DATABASE_URL is unset, the app uses JSON storage.
DATA_DIR=".data"
DATABASE_URL=""
DATABASE_SSL="false"
STORAGE_PROVIDER="postgres"

# Optional future production adapters.
TEMPORAL_ADDRESS=""
# Local sandbox verification provider. Use `podman` to enable /api/sandbox/verify.
SANDBOX_PROVIDER="local"
PODMAN_BIN="podman"
PODMAN_IMAGE="docker.io/library/node:22-alpine"
PODMAN_MEMORY="512m"
PODMAN_CPUS="1"
SANDBOX_TIMEOUT_MS="30000"
# Optional server-owned sandbox command manifest for job QA verification.
# Commands run inside the configured no-network Podman workspace when set.
SANDBOX_INSTALL_COMMAND=""
SANDBOX_BUILD_COMMAND=""
SANDBOX_TEST_COMMAND=""
SANDBOX_STATIC_ANALYSIS_COMMAND=""
# Optional job workspace checkout baseline. Use `git` to clone the target repository into
# the Podman workspace before the sandbox command manifest runs.
SANDBOX_CHECKOUT_PROVIDER="none"
SANDBOX_CHECKOUT_AUTH_PROVIDER="none"
SANDBOX_REPOSITORY_URL=""
SANDBOX_CHECKOUT_REF=""
GIT_BIN="git"
GIT_CLONE_TIMEOUT_MS="30000"
# Default GitHub target in owner/repo form for GitHub App repository verification and future repository operations.
DEFAULT_TARGET_REPOSITORY="local/workspace"
LOCAL_WORKER_POLL_MS="1000"
