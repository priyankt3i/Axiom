# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: HTTP port for the Express/Vite server.
PORT="3000"

# SESSION_SECRET: Required in production. Used to sign HTTP-only session cookies.
SESSION_SECRET="replace-with-a-long-random-secret"

# INTEGRATION_ENCRYPTION_KEY: Required in production. Used for encrypted provider credential storage.
INTEGRATION_ENCRYPTION_KEY="replace-with-a-long-random-secret-for-integrations"

# ENABLE_DEV_LOGIN: Set to true to allow local admin login outside development.
ENABLE_DEV_LOGIN="false"

# INVITE_TOKEN_TTL_HOURS: Lifetime for one-time signed invitation links.
INVITE_TOKEN_TTL_HOURS="168"

# GitHub OAuth sign-in. Callback URL must be APP_URL + /api/auth/github/callback.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_OAUTH_SCOPES="read:user user:email repo"

# Optional production storage adapter. When DATABASE_URL is unset, the app uses JSON storage.
DATA_DIR=".data"
DATABASE_URL=""
DATABASE_SSL="false"
STORAGE_PROVIDER="postgres"

# Optional future production adapters.
TEMPORAL_ADDRESS=""
DEFAULT_TARGET_REPOSITORY="local/workspace"
LOCAL_WORKER_POLL_MS="1000"
